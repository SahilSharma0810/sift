# Sift — environment variables
# Copy to .env for local dev. Production values live in Fly secrets.

# Database — Neon connection string or local Postgres
DATABASE_URL=postgresql+psycopg://sift:sift@localhost:5432/sift

# LLM provider — `stub` (default) runs deterministic canned extractions with
# no API calls. Switch to `anthropic` and set ANTHROPIC_API_KEY for real calls.
SIFT_LLM_PROVIDER=stub

# Anthropic — only required when SIFT_LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=

# Models per tier (see ADR-0001, ADR-0003 for cascade)
SIFT_MODEL_TIER_1=claude-haiku-4-5
SIFT_MODEL_TIER_2=claude-sonnet-4-6
SIFT_MODEL_TIER_3=claude-opus-4-7

# Upload storage — local path in dev, Fly volume in prod
SIFT_UPLOAD_DIR=./uploads

# Logging
SIFT_LOG_LEVEL=INFO
SIFT_LOG_FORMAT=json

# CORS — comma-separated origins for dev
SIFT_CORS_ORIGINS=http://localhost:5173

# Auth — session cookie signing + demo user
SIFT_SECRET_KEY=dev-only-secret-do-not-use-in-prod
SIFT_COOKIE_SECURE=false
SIFT_SESSION_REMEMBER_DAYS=30
SIFT_SESSION_DEFAULT_HOURS=12
SIFT_DEMO_EMAIL=ap-clerk@sift.demo
SIFT_DEMO_PASSWORD=letmein-demo
