# Sift backend — development image.
# Hot-reload via uvicorn --reload + bind-mounted source.
# The .venv lives in a named volume (see docker-compose) so the host's mac
# binaries never clobber the container's linux ones.

FROM python:3.12-slim-bookworm

ENV PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    UV_LINK_MODE=copy \
    UV_COMPILE_BYTECODE=1 \
    UV_PROJECT_ENVIRONMENT=/app/.venv

# poppler-utils for pdf2image; libglib for PyMuPDF on slim images.
RUN apt-get update && apt-get install -y --no-install-recommends \
    poppler-utils libglib2.0-0 build-essential \
 && rm -rf /var/lib/apt/lists/*

COPY --from=ghcr.io/astral-sh/uv:0.10 /uv /usr/local/bin/uv

WORKDIR /app

# Resolve + install deps at image-build time so first `docker compose up`
# is fast. uv.lock-pinned, deterministic.
COPY pyproject.toml uv.lock* ./
RUN --mount=type=cache,target=/root/.cache/uv \
    uv sync --all-groups --frozen

# Project source is bind-mounted at runtime; copy at build time so the
# image is also usable for one-shot runs (CI, debugging).
COPY . .

EXPOSE 8000

CMD ["uv", "run", "uvicorn", "app.main:app", "--host", "0.0.0.0", "--port", "8000", "--reload"]
